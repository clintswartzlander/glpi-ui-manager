{
    "name": "clintswartzlander/glpi-asset-menu-manager",
    "description": "Globally show or hide supported native GLPI Assets menu entries.",
    "type": "glpi-plugin",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "GlpiPlugin\\Assetmenumanager\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GlpiPlugin\\Assetmenumanager\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "@php scripts/lint.php"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": false
    }
}
